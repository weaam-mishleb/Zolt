# ───────────── Zolt — environment template ─────────────
# Copy to `.env` and adjust. `.env` is git-ignored.

# MySQL (consumed by docker-compose.yml and, later, the backend)
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=zolt
MYSQL_USER=zolt
MYSQL_PASSWORD=change_me_app
MYSQL_PORT=3306

# How the backend reaches MySQL (host port above)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zolt
DB_USER=zolt
DB_PASSWORD=change_me_app

# Production: a single connection string overrides the DB_* parts above.
# Managed hosts (Render/Railway/Aiven) inject this — e.g.:
# DATABASE_URL=mysql://user:pass@host:port/dbname

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# In production add your Vercel domain, e.g. https://zolt.vercel.app
# Optionally allow Vercel preview URLs:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app$

# ── Admin auth ──
# Generate the hash with:  python -m backend.app.security 'your-password'
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH='replace-with-bcrypt-hash'

# ── Kaggle / automated ETL ──
# Kaggle dataset reference "owner/dataset-name".
KAGGLE_DATASET=erlichsefi/israeli-supermarkets-data
# Place kaggle.json under  ./secrets/  (git-ignored). KAGGLE_CONFIG_DIR defaults there.
SCHEDULER_ENABLED=true
