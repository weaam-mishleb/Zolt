# ───────────── Zolt — environment template ─────────────
# Copy to `.env` and adjust. `.env` is git-ignored.

# MySQL (consumed by docker-compose.yml and, later, the backend)
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=zolt
MYSQL_USER=zolt
MYSQL_PASSWORD=change_me_app
MYSQL_PORT=3306

# How the backend reaches MySQL (host port above)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zolt
DB_USER=zolt
DB_PASSWORD=change_me_app
