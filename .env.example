# ───────────── Zolt — environment template ─────────────
# Copy to `.env` and adjust. `.env` is git-ignored.

# MySQL (consumed by docker-compose.yml and, later, the backend)
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=zolt
MYSQL_USER=zolt
MYSQL_PASSWORD=change_me_app
MYSQL_PORT=3306

# How the backend reaches MySQL (host port above)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zolt
DB_USER=zolt
DB_PASSWORD=change_me_app

# ── Admin auth ──
# Generate the hash with:  python -m backend.app.security 'your-password'
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_HOURS=1
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH='replace-with-bcrypt-hash'

# ── Kaggle / automated ETL ──
# Kaggle dataset reference "owner/dataset-name".
KAGGLE_DATASET=erlichsefi/israeli-supermarkets-data
# Place kaggle.json under  ./secrets/  (git-ignored). KAGGLE_CONFIG_DIR defaults there.
SCHEDULER_ENABLED=true
